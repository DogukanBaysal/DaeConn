      "targets": [
        {
          "format": "table",
          "rawSql": "WITH snapshot_counts AS (\n  SELECT\n    date_trunc('hour', timestamp)\n      - (extract(hour from timestamp)::int % 6) * interval '1 hour'\n      AS snapshot,\n    count(DISTINCT destination_ip) AS unique_ips\n  FROM ip_list\n  WHERE destination_ip IS NOT NULL\n  GROUP BY 1\n)\nSELECT\n  avg(unique_ips) AS mean,\n  percentile_cont(0.5) WITHIN GROUP (ORDER BY unique_ips) AS median,\n  stddev(unique_ips) AS std_dev,\n  min(unique_ips) AS min,\n  max(unique_ips) AS max\nFROM snapshot_counts;",
          "refId": "A",
          "timeColumn": "time"
        }
      ],
      "title": "Unique IPs per 6-Hour Snapshot — Summary Stats",
      "type": "table"
    },
