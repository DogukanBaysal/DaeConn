        {
          "format": "time_series",
          "group": [],
          "metricColumn": "none",
          "rawSql": "WITH bucketed AS (\n  SELECT\n    $__timeGroup(scan_timestamp, '30m') AS bucket,\n    count(DISTINCT destination_ip) AS total_ips,\n    count(DISTINCT CASE WHEN status='active' THEN destination_ip END) AS active_ips\n  FROM scanned_ips\n  WHERE $__timeFilter(scan_timestamp)\n    AND destination_ip IS NOT NULL\n  GROUP BY 1\n)\nSELECT\n  bucket AS time,\n  (active_ips::double precision / NULLIF(total_ips,0)) * 100.0 AS value\nFROM bucketed\nORDER BY 1;",
          "refId": "A",
          "select": [],
          "timeColumn": "time"
        }
      ],
      "title": "Active IP Ratio (%)",
      "type": "timeseries"
