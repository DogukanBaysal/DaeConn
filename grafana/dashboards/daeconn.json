      "targets": [
        {
          "format": "table",
          "rawSql": "WITH snapshot AS (\n  SELECT\n    date_trunc('hour', scan_timestamp)\n      - (extract(hour from scan_timestamp)::int % 6) * interval '1 hour'\n      AS snap,\n    count(DISTINCT destination_ip) AS total,\n    count(DISTINCT CASE WHEN status='active' THEN destination_ip END) AS active\n  FROM scanned_ips\n  WHERE destination_ip IS NOT NULL\n  GROUP BY 1\n)\nSELECT\n  avg(active::double precision / NULLIF(total,0) * 100.0) AS mean_ratio,\n  percentile_cont(0.5)\n    WITHIN GROUP (ORDER BY active::double precision / NULLIF(total,0))\n    * 100.0 AS median_ratio\nFROM snapshot;",
          "refId": "A",
          "timeColumn": "time"
        }
      ],
      "title": "Active IP Ratio per 6-Hour Snapshot — Summary Stats",
